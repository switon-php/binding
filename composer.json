{
    "name": "switon/binding",
    "description": "Method argument lists and typed input hydration from rules and container state for Switon Framework",
    "type": "library",
    "keywords": [
        "switon",
        "binding",
        "arguments",
        "hydration"
    ],
    "homepage": "https://github.com/switon-php/binding",
    "license": "MIT",
    "authors": [
        {
            "name": "switon",
            "email": "admin@switon.dev"
        }
    ],
    "support": {
        "source": "https://github.com/switon-php/binding",
        "issues": "https://github.com/switon-php/binding/issues",
        "docs": "https://docs.switon.dev/latest/binding"
    },
    "require": {
        "php": ">=8.3",
        "psr/container": "^2.0",
        "psr/event-dispatcher": "^1.0",
        "switon/core": "^1.0",
        "switon/event": "^1.0",
        "switon/validation": "^1.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "switon/testing": "^1.0",
        "phpstan/extension-installer": "^1.4"
    },
    "config": {
        "allow-plugins": {
            "switon/composer-extra": true,
            "phpstan/extension-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "Switon\\Binding\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Switon\\Binding\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpstan": "@php vendor/bin/phpstan analyse",
        "test:unit": "@php vendor/bin/phpunit --configuration tests/phpunit.xml.dist --testsuite=unit --display-deprecations --display-phpunit-notices",
        "test": "@php vendor/bin/phpunit --configuration tests/phpunit.xml.dist --testsuite=all --display-deprecations --display-phpunit-notices"
    },
    "extra": {
        "branch-alias": {
            "dev-dev": "1.0.x-dev"
        }
    }
}
